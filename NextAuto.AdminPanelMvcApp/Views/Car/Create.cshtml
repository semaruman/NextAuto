@model NextAuto.AdminPanelMvcApp.Models.CarFormViewModel
@{
    ViewData["Title"] = "Добавить автомобиль";
}

<h1 class="page-title">@ViewData["Title"]</h1>
<p class="page-subtitle">Заполните данные о новом автомобиле</p>

<div class="card">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Brand"></label>
            <input asp-for="Brand" class="form-control"/>
            <span asp-validation-for="Brand" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Model"></label>
            <input asp-for="Model" class="form-control"/>
            <span asp-validation-for="Model" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Year"></label>
            <input asp-for="Year" class="form-control" type="number"/>
            <span asp-validation-for="Year" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Mileage"></label>
            <input asp-for="Mileage" class="form-control" type="number"/>
            <span asp-validation-for="Mileage" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price"></label>
            <input asp-for="Price" class="form-control" type="number" step="0.01"/>
            <span asp-validation-for="Price" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="ImageUrl"></label>
            <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg"/>
            <span asp-validation-for="ImageUrl" class="field-validation-error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Сохранить</button>
            <a asp-action="Index" class="btn btn-secondary">Отмена</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
