<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — NextAuto Admin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    <header class="header">
        <div class="container header-inner">
            <a class="logo" asp-controller="Admin" asp-action="Index">NextAuto Admin</a>
            <nav class="nav">
                <a asp-controller="Admin" asp-action="Index">Главная</a>
                <a asp-controller="Car" asp-action="Index">Автомобили</a>
                <a asp-controller="Client" asp-action="Index">Клиенты</a>
            </nav>
            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                @Html.AntiForgeryToken()
                <span class="user-name">@User.Identity.Name</span>
                <button type="submit" class="btn btn-secondary">Выйти</button>
            </form>
        </div>
    </header>
}

<main class="container main">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }
    @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
